<Window
    x:Class="TanaHub.UI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:conv="clr-namespace:TanaHub.UI.Views.Converters"
    xmlns:pages="clr-namespace:TanaHub.UI.Views.Pages"
    xmlns:controls="clr-namespace:TanaHub.UI.Views.Controls"
    x:DataType="vm:MainWindowViewModel"
    Title="{Binding AppName}"
    Width="1180"
    Height="760"
    MinWidth="920"
    MinHeight="600"
    Background="{DynamicResource TanaHubBackgroundBrush}">

  <Grid RowDefinitions="60,*">

    <!-- ── Topbar ─────────────────────────────────────────────── -->
    <Border Grid.Row="0" Background="{DynamicResource TanaHubSurfaceBrush}" BorderThickness="0,0,0,1">
      <Border.BorderBrush>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#9B6EF878" Offset="0"/>
          <GradientStop Color="#22D3EE40" Offset="0.40"/>
          <GradientStop Color="#2C224400" Offset="1"/>
        </LinearGradientBrush>
      </Border.BorderBrush>

      <Grid ColumnDefinitions="220,*,Auto" Margin="18,0">

        <!-- Logo -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="11">
          <Border Width="34" Height="34" CornerRadius="10" ClipToBounds="True">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#9B6EF8" Offset="0"/>
                <GradientStop Color="#22D3EE" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <material:MaterialIcon
                Width="18" Height="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="#100B1B"
                Kind="PlayBoxMultiple"/>
          </Border>
          <StackPanel Spacing="1">
            <TextBlock
                Text="TanaHub"
                FontSize="15"
                FontWeight="Bold"
                Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <TextBlock
                Text="Anime · Manga"
                FontSize="10"
                Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>
        </StackPanel>

        <!-- Search -->
        <Grid Grid.Column="1" VerticalAlignment="Center">
          <TextBox
              x:Name="SearchBox"
              Height="34"
              PlaceholderText="Search anime, manga, genres..."
              Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              LostFocus="SearchBox_OnLostFocus">
            <TextBox.InnerLeftContent>
              <material:MaterialIcon
                  Width="15" Height="15"
                  Kind="Magnify"
                  Margin="8,0,4,0"
                  Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </TextBox.InnerLeftContent>
            <TextBox.InnerRightContent>
              <Button Width="28" Height="28" Margin="0,0,3,0" Padding="0"
                      Command="{Binding SearchCommand}"
                      ToolTip.Tip="Search (Enter)">
                <material:MaterialIcon Width="14" Height="14" Kind="ArrowRight"/>
              </Button>
            </TextBox.InnerRightContent>
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
              <KeyBinding Gesture="Escape" Command="{Binding CloseSearchDropdownCommand}"/>
            </TextBox.KeyBindings>
          </TextBox>

          <Popup
              PlacementTarget="{Binding #SearchBox}"
              Placement="BottomEdgeAlignedLeft"
              IsOpen="{Binding IsSearchDropdownOpen, Mode=TwoWay}"
              IsLightDismissEnabled="True"
              MinWidth="{Binding #SearchBox.Bounds.Width}">
            <Border
                Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
                CornerRadius="14"
                BoxShadow="0 8 32 0 #50000000"
                ClipToBounds="True">
              <StackPanel>
                <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                  <ItemsControl ItemsSource="{Binding SearchDropdownResults}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:MediaSearchResultViewModel">
                        <Button Classes="row" Padding="12,9" CornerRadius="0"
                                Command="{Binding OpenDetailCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                          <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                            <Border Width="34" Height="48" CornerRadius="7" ClipToBounds="True"
                                    Background="{DynamicResource TanaHubAccentGlowBrush}">
                              <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                              <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                         Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                                         TextTrimming="CharacterEllipsis"/>
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Background="{DynamicResource TanaHubAccentGlowBrush}"
                                        CornerRadius="4" Padding="5,2">
                                  <TextBlock Text="{Binding Format}" FontSize="10" FontWeight="SemiBold"
                                             Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
                                </Border>
                                <Border Background="{DynamicResource TanaHubSurfaceElevatedBrush}"
                                        CornerRadius="4" Padding="5,2">
                                  <TextBlock Text="{Binding Status}" FontSize="10"
                                             Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                                </Border>
                                <TextBlock Text="{Binding Year}" FontSize="11"
                                           Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                  <material:MaterialIcon Width="11" Height="11" Kind="StarHalfFull"
                                                         Foreground="{DynamicResource TanaHubAmberBrush}"/>
                                  <TextBlock Classes="mono" Text="{Binding Score}" FontSize="11"
                                             Foreground="{DynamicResource TanaHubAmberBrush}"/>
                                </StackPanel>
                              </StackPanel>
                            </StackPanel>
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <Button Classes="ghost" Command="{Binding SearchCommand}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10" CornerRadius="0">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock
                        Text="{Binding SearchText, StringFormat='See all results for «{0}»'}"
                        FontSize="12"
                        Foreground="{DynamicResource TanaHubAccentLightBrush}"
                        TextTrimming="CharacterEllipsis"/>
                    <material:MaterialIcon Grid.Column="1" Width="13" Height="13" Kind="ArrowRight"
                                           Foreground="{DynamicResource TanaHubAccentLightBrush}"
                                           VerticalAlignment="Center"/>
                  </Grid>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>

        <!-- Offline/cache status chip -->
        <Border
            Grid.Column="2"
            Margin="18,0,0,0"
            Padding="10,7"
            VerticalAlignment="Center"
            Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
            BorderBrush="{DynamicResource TanaHubBorderBrush}"
            BorderThickness="1"
            CornerRadius="9"
            ToolTip.Tip="{Binding AppConnectionStatusDetail}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Grid Width="7" Height="7" VerticalAlignment="Center">
              <Border
                  CornerRadius="4"
                  Background="{DynamicResource TanaHubGreenBrush}"
                  IsVisible="{Binding IsConnectionStatusOnline}"/>
              <Border
                  CornerRadius="4"
                  Background="{DynamicResource TanaHubAmberBrush}"
                  IsVisible="{Binding IsConnectionStatusCached}"/>
              <Border
                  CornerRadius="4"
                  Background="{DynamicResource TanaHubRedBrush}"
                  IsVisible="{Binding IsConnectionStatusOffline}"/>
            </Grid>
            <StackPanel Spacing="0">
              <TextBlock
                  Text="{Binding AppConnectionStatusText}"
                  FontSize="11"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
              <TextBlock
                  Text="{Binding AppConnectionStatusDetail}"
                  FontSize="10"
                  MaxWidth="150"
                  TextTrimming="CharacterEllipsis"
                  Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- ── Body ───────────────────────────────────────────────── -->
    <Grid Grid.Row="1" ColumnDefinitions="220,*">

      <!-- Sidebar -->
      <Border
          Background="{DynamicResource TanaHubSurfaceBrush}"
          BorderBrush="{DynamicResource TanaHubBorderBrush}"
          BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
          <Grid Margin="12,16,12,0">
            <!-- Sliding selection highlight -->
            <Border
                Width="196"
                Height="40"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{DynamicResource TanaHubAccentGlowBrush}"
                BorderBrush="{DynamicResource TanaHubAccentBrush}"
                BorderThickness="1"
                CornerRadius="12">
              <Border.RenderTransform>
                <TranslateTransform Y="{Binding SelectedNavigationOffset}">
                  <TranslateTransform.Transitions>
                    <Transitions>
                      <DoubleTransition Property="Y" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                    </Transitions>
                  </TranslateTransform.Transitions>
                </TranslateTransform>
              </Border.RenderTransform>
            </Border>

            <ListBox
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                ItemsSource="{Binding NavigationItems}"
                SelectedItem="{Binding SelectedNavigationItem}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavigationItemViewModel">
                  <Grid
                      Height="40"
                      ColumnDefinitions="42,*"
                      ColumnSpacing="8"
                      ToolTip.Tip="{Binding Summary}">
                    <Border
                        Classes="nav-icon-border"
                        Width="30"
                        Height="30"
                        CornerRadius="9"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource TanaHubSurfaceRaisedBrush}">
                      <material:MaterialIcon
                          Classes="nav-icon"
                          Width="16" Height="16"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                          Kind="{Binding Key, Converter={x:Static conv:NavKeyToIconConverter.Instance}}"/>
                    </Border>
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding Title}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
                <Style Selector="ListBoxItem /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="CornerRadius" Value="12"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <!-- Hovering the active item must not paint the hover bg over the sliding indicator -->
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <!-- Suppress FluentTheme focus highlight so keyboard nav stays clean -->
                <Style Selector="ListBoxItem:focus-visible /template/ ContentPresenter">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceHoverBrush}"/>
                  <Setter Property="CornerRadius" Value="12"/>
                </Style>
                <Style Selector="ListBoxItem:selected Border.nav-icon-border">
                  <Setter Property="Background" Value="{DynamicResource TanaHubAccentGlowBrush}"/>
                </Style>
                <Style Selector="ListBoxItem:selected material|MaterialIcon.nav-icon">
                  <Setter Property="Foreground" Value="{DynamicResource TanaHubAccentLightBrush}"/>
                </Style>
                <Style Selector="Border.nav-icon-border">
                  <Setter Property="Transitions">
                    <Setter.Value>
                      <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.18"/>
                      </Transitions>
                    </Setter.Value>
                  </Setter>
                </Style>
                <Style Selector="material|MaterialIcon.nav-icon">
                  <Setter Property="Transitions">
                    <Setter.Value>
                      <Transitions>
                        <BrushTransition Property="Foreground" Duration="0:0:0.18"/>
                      </Transitions>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ListBox.Styles>
            </ListBox>
          </Grid>

          <!-- Sidebar footer -->
          <Border
              Grid.Row="1"
              Margin="12,0,12,14"
              Padding="10,7"
              CornerRadius="8"
              Background="{DynamicResource TanaHubSurfaceRaisedBrush}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="12" Height="12" Kind="CodeBraces" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
              <TextBlock Text="Preview build" FontSize="10" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- Main content -->
      <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20" MaxWidth="1180">
          <StackPanel Spacing="22">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
              <!-- Back button -->
              <Button
                  Grid.Column="0"
                  Classes="ghost"
                  IsVisible="{Binding IsDetailVisible}"
                  VerticalAlignment="Center"
                  Padding="10,7"
                  Command="{Binding GoBackCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <material:MaterialIcon Width="16" Height="16" Kind="ChevronLeft"/>
                  <TextBlock Text="Back"/>
                </StackPanel>
              </Button>

              <!-- Page title -->
              <Grid Grid.Column="1" ColumnDefinitions="3,*" ColumnSpacing="10" VerticalAlignment="Center">
                <Border
                    Width="3"
                    Height="28"
                    CornerRadius="2"
                    VerticalAlignment="Center">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                      <GradientStop Color="#9B6EF8" Offset="0"/>
                      <GradientStop Color="#22D3EE" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                  <TextBlock
                      Text="{Binding CurrentPageTitle}"
                      FontSize="26"
                      FontWeight="Bold"
                      Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
                  <TextBlock
                      Text="{Binding CurrentPageSummary}"
                      FontSize="12"
                      Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                </StackPanel>
              </Grid>

              <!-- Search status -->
              <Border
                  Grid.Column="2"
                  Padding="12,7"
                  VerticalAlignment="Center"
                  Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
                  CornerRadius="9">
                <TextBlock
                    Text="{Binding SearchStatus}"
                    FontSize="11"
                    Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
              </Border>
            </Grid>

            <pages:HomeView IsVisible="{Binding IsHomeVisible}"/>
            <pages:DiscoverView IsVisible="{Binding IsDiscoverVisible}"/>
            <pages:LibraryView IsVisible="{Binding IsLibraryVisible}"/>
            <pages:ScheduleView IsVisible="{Binding IsScheduleVisible}"/>
            <pages:RecognizeView IsVisible="{Binding IsRecognizeVisible}"/>
            <pages:SettingsView IsVisible="{Binding IsSettingsVisible}"/>

            <ContentControl
                IsVisible="{Binding IsDetailVisible}"
                Content="{Binding SelectedMedia}">
              <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:MediaDetailViewModel">
                  <pages:TitleDetailView/>
                </DataTemplate>
              </ContentControl.ContentTemplate>
            </ContentControl>
          </StackPanel>
        </Grid>
      </ScrollViewer>

    </Grid>
  </Grid>
</Window>
