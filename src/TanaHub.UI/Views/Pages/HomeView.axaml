<UserControl
    x:Class="TanaHub.UI.Views.Pages.HomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:TanaHub.UI.Views.Controls"
    x:DataType="vm:MainWindowViewModel">

  <!-- Two-column dashboard: left = content, right = schedule + stats -->
  <Grid ColumnDefinitions="1.3*,*" ColumnSpacing="22">

    <!-- ── Left column: In Progress + Recently Updated ─────────── -->
    <StackPanel Spacing="22">

      <!-- In Progress -->
      <StackPanel Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Width="3" Height="13" CornerRadius="2" VerticalAlignment="Center"
                  Background="{DynamicResource TanaHubCyanBrush}"/>
          <TextBlock Text="IN PROGRESS" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TanaHubCyanBrush}"/>
        </StackPanel>

        <!-- Empty state -->
        <Border
            Classes="panel"
            IsVisible="{Binding !HasContinueItems}"
            Padding="24,36">
          <StackPanel HorizontalAlignment="Center" Spacing="12">
            <material:MaterialIcon Width="40" Height="40" Kind="PlayCircleOutline"
                                   Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
            <TextBlock Text="Nothing in progress" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Add titles to your library to start tracking."
                       FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <Button HorizontalAlignment="Center" Margin="0,4,0,0"
                    Command="{Binding NavigateToDiscoverCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="14" Height="14" Kind="Magnify"/>
                <TextBlock Text="Browse titles"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- Horizontal scroll cards -->
        <ScrollViewer IsVisible="{Binding HasContinueItems}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding ContinueItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="12"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LibraryEntryViewModel">
                <Button
                    Classes="card"
                    Command="{Binding OpenDetailCommand}"
                    Width="144"
                    Height="210"
                    RenderTransformOrigin="0.5,0.5">
                  <Border CornerRadius="12" ClipToBounds="True"
                          BoxShadow="0 4 16 0 #28000000">
                    <Grid>
                      <!-- Fallback gradient + poster image -->
                      <Border>
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#3B1D63" Offset="0"/>
                            <GradientStop Color="#14263B" Offset="0.62"/>
                            <GradientStop Color="#0E0B15" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                      </Border>
                      <!-- Bottom vignette fade -->
                      <Border VerticalAlignment="Bottom" Height="88">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#F207060E" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                      </Border>
                      <!-- Title + progress overlay -->
                      <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10" Spacing="3">
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Classes="mono" Text="{Binding Progress}" FontSize="11"
                                     Foreground="{DynamicResource TanaHubCyanBrush}"/>
                          <TextBlock Classes="mono" Grid.Column="1" Text="{Binding Score}"
                                     FontSize="11" Foreground="{DynamicResource TanaHubAmberBrush}"/>
                        </Grid>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>

      <!-- Recommended -->
      <StackPanel IsVisible="{Binding HasRecommendedItems}" Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="3" Height="13" CornerRadius="2" VerticalAlignment="Center"
                    Background="{DynamicResource TanaHubAmberBrush}"/>
            <StackPanel Spacing="1">
              <TextBlock Text="RECOMMENDED FOR YOU" FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource TanaHubAmberBrush}"/>
              <TextBlock Text="{Binding RecommendationSummary}" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          <Button Classes="ghost" Grid.Column="1" Height="24" Padding="8,0"
                  Command="{Binding NavigateToDiscoverCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="Discover" FontSize="11"/>
              <material:MaterialIcon Width="12" Height="12" Kind="ChevronRight"/>
            </StackPanel>
          </Button>
        </Grid>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding RecommendedItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="12"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:MediaSearchResultViewModel">
                <Button Classes="card" Command="{Binding OpenDetailCommand}"
                        Width="148" Height="224" RenderTransformOrigin="0.5,0.5">
                  <Border CornerRadius="12" ClipToBounds="True"
                          BoxShadow="0 4 16 0 #28000000">
                    <Grid>
                      <Border>
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#3B1D63" Offset="0"/>
                            <GradientStop Color="#14263B" Offset="0.62"/>
                            <GradientStop Color="#0E0B15" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                      </Border>
                      <Border VerticalAlignment="Bottom" Height="96">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#F207060E" Offset="1"/>
                          </LinearGradientBrush>
                        </Border.Background>
                      </Border>
                      <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10" Spacing="3">
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Genres}" FontSize="10"
                                   Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Classes="mono" Text="{Binding Type}" FontSize="10"
                                     Foreground="{DynamicResource TanaHubCyanBrush}"/>
                          <TextBlock Classes="mono" Grid.Column="1" Text="{Binding Score}"
                                     FontSize="10" Foreground="{DynamicResource TanaHubAmberBrush}"/>
                        </Grid>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>

      <!-- Recently Updated -->
      <StackPanel Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Width="3" Height="13" CornerRadius="2" VerticalAlignment="Center"
                  Background="{DynamicResource TanaHubAccentLightBrush}"/>
          <TextBlock Text="RECENTLY UPDATED" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
          </StackPanel>
          <Button Classes="ghost" Grid.Column="1" Height="24" Padding="8,0"
                  Command="{Binding NavigateToLibraryCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="Library" FontSize="11"/>
              <material:MaterialIcon Width="12" Height="12" Kind="ChevronRight"/>
            </StackPanel>
          </Button>
        </Grid>

        <!-- Empty state -->
        <Border
            Classes="panel"
            IsVisible="{Binding IsLibraryEmpty}"
            Padding="20,24">
          <StackPanel HorizontalAlignment="Center" Spacing="10">
            <material:MaterialIcon Width="32" Height="32" Kind="Bookshelf"
                                   Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
            <TextBlock Text="Your library is empty" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Titles you add from Discover will appear here."
                       FontSize="11" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Entries — outer ScrollViewer handles all vertical scrolling -->
        <ItemsControl IsVisible="{Binding !IsLibraryEmpty}" ItemsSource="{Binding LibraryEntries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:LibraryEntryViewModel">
              <Button Classes="row" Margin="0,0,0,5" Command="{Binding OpenDetailCommand}">
                <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="10">
                  <Border Width="34" Height="48" CornerRadius="7"
                          Background="{DynamicResource TanaHubAccentGlowBrush}"
                          ClipToBounds="True" VerticalAlignment="Center">
                    <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Status}" FontSize="11"
                               Foreground="{Binding StatusForeground}"/>
                  </StackPanel>
                  <TextBlock Classes="mono" Grid.Column="2" Text="{Binding Progress}"
                             FontSize="12" VerticalAlignment="Center"
                             Foreground="{DynamicResource TanaHubCyanBrush}"/>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>

    <!-- ── Right column: Airing Today + Stats ──────────────────── -->
    <StackPanel Grid.Column="1" Spacing="22">

      <!-- Airing Today (capped height prevents column overflow) -->
      <StackPanel Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Width="3" Height="13" CornerRadius="2" VerticalAlignment="Center"
                  Background="{DynamicResource TanaHubSakuraBrush}"/>
          <TextBlock Text="AIRING TODAY" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TanaHubSakuraBrush}"/>
          </StackPanel>
          <Button Classes="ghost" Grid.Column="1" Height="24" Padding="8,0"
                  Command="{Binding NavigateToScheduleCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="Schedule" FontSize="11"/>
              <material:MaterialIcon Width="12" Height="12" Kind="ChevronRight"/>
            </StackPanel>
          </Button>
        </Grid>

        <!-- Empty state -->
        <Border
            Classes="panel"
            IsVisible="{Binding !HasScheduleItems}"
            Padding="20,28">
          <StackPanel HorizontalAlignment="Center" Spacing="10">
            <material:MaterialIcon Width="32" Height="32" Kind="CalendarBlank"
                                   Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
            <TextBlock Text="No episodes today" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Episodes from your library will appear here on their air date."
                       FontSize="11" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- Schedule rows — outer ScrollViewer handles all vertical scrolling -->
        <ItemsControl IsVisible="{Binding HasScheduleItems}" ItemsSource="{Binding ScheduleItems}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ScheduleItemViewModel">
              <Button Classes="row" Margin="0,0,0,6" Command="{Binding OpenDetailCommand}">
                <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="10">
                  <Border Width="38" Height="52" CornerRadius="8" ClipToBounds="True"
                          VerticalAlignment="Center">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#1B3040" Offset="0"/>
                        <GradientStop Color="#0E0B15" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Detail}" FontSize="11"
                               Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3"
                              HorizontalAlignment="Right">
                    <TextBlock Classes="mono" Text="{Binding Episode}" FontSize="11"
                               FontWeight="SemiBold" Foreground="{DynamicResource TanaHubCyanBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock Classes="mono" Text="{Binding Time}" FontSize="10"
                               Foreground="{DynamicResource TanaHubTextMutedBrush}"
                               HorizontalAlignment="Right"/>
                  </StackPanel>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <!-- Stats -->
      <ItemsControl ItemsSource="{Binding DashboardMetrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="10"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DashboardMetricViewModel">
            <Border Classes="card" Padding="16,14">
              <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Border Width="36" Height="36" CornerRadius="10"
                          Background="{DynamicResource TanaHubAccentGlowBrush}">
                    <material:MaterialIcon Width="18" Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Kind="{Binding Icon}"
                                          Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="{Binding Label}" FontSize="11"
                               Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                    <TextBlock Classes="mono" Text="{Binding Value}" FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
                  </StackPanel>
                </Grid>
                <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding Detail}"
                           FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Charts -->
      <ItemsControl ItemsSource="{Binding DashboardCharts}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="10"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DashboardChartViewModel">
            <Border Classes="card" Padding="16,14">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Border Width="32" Height="32" CornerRadius="9"
                          Background="{DynamicResource TanaHubAccentGlowBrush}">
                    <material:MaterialIcon Width="16" Height="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Kind="{Binding Icon}"
                                           Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Detail}" FontSize="11"
                               Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
                  </StackPanel>
                </Grid>

                <TextBlock IsVisible="{Binding !HasSegments}"
                           Text="Add titles to your library to see this chart."
                           FontSize="11"
                           Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>

                <ItemsControl IsVisible="{Binding HasSegments}" ItemsSource="{Binding Segments}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Spacing="9"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DashboardChartSegmentViewModel">
                      <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Label}" FontSize="11"
                                     Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Column="1" Classes="mono" Text="{Binding CountText}" FontSize="10"
                                     Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
                          <TextBlock Grid.Column="2" Classes="mono" Text="{Binding PercentText}" FontSize="10"
                                     Foreground="{DynamicResource TanaHubCyanBrush}"/>
                        </Grid>
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Percent}" Height="5"/>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>

  </Grid>
</UserControl>
