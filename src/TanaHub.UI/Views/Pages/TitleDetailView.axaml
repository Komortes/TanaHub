<UserControl
    x:Class="TanaHub.UI.Views.Pages.TitleDetailView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:domain="clr-namespace:TanaHub.Domain.Models;assembly=TanaHub.Domain"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:TanaHub.UI.Views.Controls"
    x:DataType="vm:MediaDetailViewModel">

  <UserControl.Styles>

    <!-- Score bar: 8×22 thin fill bar, colour-coded by band -->
    <Style Selector="Button.score-bar">
      <Setter Property="Width" Value="8"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.1"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Button.score-bar.b1.active, Button.score-bar.b2.active, Button.score-bar.b3.active">
      <Setter Property="Background" Value="#EF4444"/>
    </Style>
    <Style Selector="Button.score-bar.b4.active, Button.score-bar.b5.active, Button.score-bar.b6.active">
      <Setter Property="Background" Value="#F59E0B"/>
    </Style>
    <Style Selector="Button.score-bar.b7.active, Button.score-bar.b8.active">
      <Setter Property="Background" Value="#84CC16"/>
    </Style>
    <Style Selector="Button.score-bar.b9.active, Button.score-bar.b10.active">
      <Setter Property="Background" Value="#10B981"/>
    </Style>
    <Style Selector="Button.score-bar:pointerover">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- Status pills — each status has its own active color -->
    <Style Selector="Button.status-pill">
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextMutedBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}"/>
    </Style>
    <Style Selector="Button.status-pill:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderLightBrush}"/>
    </Style>
    <Style Selector="Button.current.active">
      <Setter Property="Background" Value="#10B981"/>
      <Setter Property="BorderBrush" Value="#10B981"/>
      <Setter Property="Foreground" Value="#0A1F17"/>
    </Style>
    <Style Selector="Button.planning.active">
      <Setter Property="Background" Value="#3B82F6"/>
      <Setter Property="BorderBrush" Value="#3B82F6"/>
      <Setter Property="Foreground" Value="#0D1831"/>
    </Style>
    <Style Selector="Button.paused.active">
      <Setter Property="Background" Value="#F97316"/>
      <Setter Property="BorderBrush" Value="#F97316"/>
      <Setter Property="Foreground" Value="#1F0E03"/>
    </Style>
    <Style Selector="Button.completed.active">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}"/>
      <Setter Property="Foreground" Value="#0E0919"/>
    </Style>
    <Style Selector="Button.dropped.active">
      <Setter Property="Background" Value="#EF4444"/>
      <Setter Property="BorderBrush" Value="#EF4444"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>

  </UserControl.Styles>

  <StackPanel Spacing="20">

    <!-- ── Hero ───────────────────────────────────────────────────── -->
    <StackPanel Spacing="0">

      <Border Height="240" CornerRadius="12" ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#261540" Offset="0"/>
            <GradientStop Color="#0E0C1A" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <controls:RemoteImage SourceUri="{Binding BannerUri}" IsVisible="{Binding HasBanner}"/>
          <Border VerticalAlignment="Bottom" Height="160">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#00000000" Offset="0"/>
                <GradientStop Color="#EE07060E" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </Grid>
      </Border>

      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24" Margin="0,-90,0,0">

        <!-- Poster -->
        <Border Width="160" Height="228" VerticalAlignment="Top"
                CornerRadius="10" ClipToBounds="True"
                BoxShadow="0 8 32 0 #4C000000">
          <Grid>
            <Border>
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#3B1D63" Offset="0"/>
                  <GradientStop Color="#10131F" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>
            <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
          </Grid>
        </Border>

        <!-- Info column -->
        <StackPanel Grid.Column="1" Margin="0,20,0,0" Spacing="10">

          <!-- Type / Year / Status chips -->
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Border Classes="chip-accent">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <material:MaterialIcon Width="13" Height="13" Kind="{Binding TypeIcon}"
                                       Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
                <TextBlock Text="{Binding Format}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
              </StackPanel>
            </Border>
            <Border Classes="chip">
              <TextBlock Classes="mono" Text="{Binding Year}" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            </Border>
            <Border Classes="chip">
              <TextBlock Text="{Binding ReleaseStatus}" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            </Border>
          </StackPanel>

          <!-- Title -->
          <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold"
                     TextWrapping="Wrap" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>

          <!-- Romaji subtitle -->
          <TextBlock Text="{Binding RomajiTitle}" IsVisible="{Binding HasRomajiTitle}"
                     FontSize="13" TextTrimming="CharacterEllipsis"
                     Foreground="{DynamicResource TanaHubTextMutedBrush}"/>

          <!-- Community score + library progress on the same row -->
          <Grid ColumnDefinitions="Auto,*" Margin="0,2,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <material:MaterialIcon Width="15" Height="15" Kind="StarHalfFull"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource TanaHubAmberBrush}"/>
              <TextBlock Classes="mono" Text="{Binding Score}" FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource TanaHubTextPrimaryBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="/ 10" FontSize="11" VerticalAlignment="Center" Margin="1,0,0,0"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <Border Grid.Column="1" Classes="chip" IsVisible="{Binding IsInLibrary}"
                    HorizontalAlignment="Left" Padding="10,6" Margin="14,0,0,0" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="12" Height="12" Kind="PlayBoxOutline"
                                       Foreground="{DynamicResource TanaHubCyanBrush}"/>
                <TextBlock Classes="mono" Text="{Binding LibraryProgress}" FontSize="13"
                           FontWeight="SemiBold" Foreground="{DynamicResource TanaHubCyanBrush}"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- ── Library actions ──────────────────────────────────── -->
          <Button IsVisible="{Binding !IsInLibrary}" Margin="0,4,0,0"
                  Command="{Binding AddToLibraryCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="BookmarkPlusOutline"/>
              <TextBlock Text="Add to Library"/>
            </StackPanel>
          </Button>

          <!-- In library: status pills + score on same row -->
          <StackPanel IsVisible="{Binding IsInLibrary}" Spacing="8" Margin="0,4,0,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Classes="status-pill current"
                        Classes.active="{Binding IsStatusCurrent}"
                        Command="{Binding MarkCurrentCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="13" Height="13" Kind="PlayCircleOutline"/>
                    <TextBlock Text="Watching"/>
                  </StackPanel>
                </Button>
                <Button Classes="status-pill planning"
                        Classes.active="{Binding IsStatusPlanning}"
                        Command="{Binding MarkPlanningCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="13" Height="13" Kind="BookmarkPlusOutline"/>
                    <TextBlock Text="Planning"/>
                  </StackPanel>
                </Button>
                <Button Classes="status-pill paused"
                        Classes.active="{Binding IsStatusPaused}"
                        Command="{Binding MarkPausedCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="13" Height="13" Kind="PauseCircleOutline"/>
                    <TextBlock Text="Paused"/>
                  </StackPanel>
                </Button>
                <Button Classes="status-pill completed"
                        Classes.active="{Binding IsStatusCompleted}"
                        Command="{Binding MarkCompletedCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="13" Height="13" Kind="CheckCircleOutline"/>
                    <TextBlock Text="Completed"/>
                  </StackPanel>
                </Button>
                <Button Classes="status-pill dropped"
                        Classes.active="{Binding IsStatusDropped}"
                        Command="{Binding MarkDroppedCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="13" Height="13" Kind="CloseCircleOutline"/>
                    <TextBlock Text="Dropped"/>
                  </StackPanel>
                </Button>
              </StackPanel>
              <!-- Score: chip showing current value + fill bars -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Border Width="28" Height="24" CornerRadius="4"
                        Background="{DynamicResource TanaHubAccentGlowBrush}">
                  <TextBlock Classes="mono" Text="{Binding UserScoreDisplay}" FontSize="11" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="3">
                  <Button Classes="score-bar b1" Classes.active="{Binding IsScoreAtLeast1}"
                          Command="{Binding SetScoreCommand}" CommandParameter="1"/>
                  <Button Classes="score-bar b2" Classes.active="{Binding IsScoreAtLeast2}"
                          Command="{Binding SetScoreCommand}" CommandParameter="2"/>
                  <Button Classes="score-bar b3" Classes.active="{Binding IsScoreAtLeast3}"
                          Command="{Binding SetScoreCommand}" CommandParameter="3"/>
                  <Button Classes="score-bar b4" Classes.active="{Binding IsScoreAtLeast4}"
                          Command="{Binding SetScoreCommand}" CommandParameter="4"/>
                  <Button Classes="score-bar b5" Classes.active="{Binding IsScoreAtLeast5}"
                          Command="{Binding SetScoreCommand}" CommandParameter="5"/>
                  <Button Classes="score-bar b6" Classes.active="{Binding IsScoreAtLeast6}"
                          Command="{Binding SetScoreCommand}" CommandParameter="6"/>
                  <Button Classes="score-bar b7" Classes.active="{Binding IsScoreAtLeast7}"
                          Command="{Binding SetScoreCommand}" CommandParameter="7"/>
                  <Button Classes="score-bar b8" Classes.active="{Binding IsScoreAtLeast8}"
                          Command="{Binding SetScoreCommand}" CommandParameter="8"/>
                  <Button Classes="score-bar b9" Classes.active="{Binding IsScoreAtLeast9}"
                          Command="{Binding SetScoreCommand}" CommandParameter="9"/>
                  <Button Classes="score-bar b10" Classes.active="{Binding IsScoreAtLeast10}"
                          Command="{Binding SetScoreCommand}" CommandParameter="10"/>
                </StackPanel>
              </StackPanel>
            </Grid>

            <!-- Quick actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="ghost" Height="34" Padding="10,0"
                      Command="{Binding SetProgressZeroCommand}"
                      ToolTip.Tip="Reset to 0">
                <material:MaterialIcon Width="15" Height="15" Kind="SkipPreviousOutline"/>
              </Button>
              <Button Classes="ghost" Height="34" Padding="10,0"
                      Command="{Binding IncrementProgressCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <material:MaterialIcon Width="14" Height="14" Kind="Plus"/>
                  <TextBlock Text="{Binding IncrementLabel}" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button Classes="ghost" Height="34" Padding="10,0"
                      IsVisible="{Binding CanSetToMax}"
                      Command="{Binding SetProgressMaxCommand}"
                      ToolTip.Tip="Set to max">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <material:MaterialIcon Width="14" Height="14" Kind="SkipNextOutline"/>
                  <TextBlock Text="{Binding ProgressValue}" FontSize="12"/>
                </StackPanel>
              </Button>
              <Button Classes="danger" Width="34" Height="34" Padding="0"
                      Command="{Binding RemoveCommand}" ToolTip.Tip="Remove from library">
                <material:MaterialIcon Width="15" Height="15" Kind="TrashCanOutline"/>
              </Button>
            </StackPanel>
          </StackPanel>

        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- ── Details + Genres / Organize ──────────────────────────── -->
    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">

      <!-- Left: Details and Genres combined -->
      <Border Classes="panel">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Classes="eyebrow-bar" Background="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Classes="eyebrow" Text="DETAILS" LetterSpacing="1"
                       Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="16">
            <Border Grid.Row="0" Classes="chip" Padding="7,3" HorizontalAlignment="Left">
              <TextBlock Text="Format" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </Border>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Format}" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <Border Grid.Row="1" Classes="chip" Padding="7,3" HorizontalAlignment="Left">
              <TextBlock Text="Year" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </Border>
            <TextBlock Classes="mono" Grid.Row="1" Grid.Column="1" Text="{Binding Year}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <Border Grid.Row="2" Classes="chip" Padding="7,3" HorizontalAlignment="Left">
              <TextBlock Text="Status" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </Border>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ReleaseStatus}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <Border Grid.Row="3" Classes="chip" Padding="7,3" HorizontalAlignment="Left">
              <TextBlock Text="{Binding ProgressLabel}" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </Border>
            <TextBlock Classes="mono" Grid.Row="3" Grid.Column="1" Text="{Binding ProgressValue}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubCyanBrush}"/>
            <Border Grid.Row="4" Classes="chip" Padding="7,3" HorizontalAlignment="Left"
                    IsVisible="{Binding HasStudio}">
              <TextBlock Text="Studio" FontSize="11"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </Border>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Studio}" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center" IsVisible="{Binding HasStudio}"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          </Grid>

          <Border Classes="divider"/>

          <ItemsControl ItemsSource="{Binding Genres}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="chip" Margin="0,0,6,6" Padding="10,5">
                  <TextBlock Text="{Binding}" FontSize="12"
                             Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Right: Organize (library only) -->
      <Border Grid.Column="1" Classes="panel" IsVisible="{Binding IsInLibrary}">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Classes="eyebrow-bar" Background="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Classes="eyebrow" Text="ORGANIZE" LetterSpacing="1"
                       Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Tags" FontSize="12"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox x:Name="TagsBox"
                       Text="{Binding TagsText, Mode=OneWay}"
                       PlaceholderText="rewatch, comfort, seasonal"
                       FontSize="12">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Ctrl+Enter"
                              Command="{Binding SaveTagsCommand}"
                              CommandParameter="{Binding #TagsBox.Text}"/>
                </TextBox.KeyBindings>
              </TextBox>
              <Button Grid.Column="1" Classes="ghost" Width="34" Height="34" Padding="0"
                      Command="{Binding SaveTagsCommand}"
                      CommandParameter="{Binding #TagsBox.Text}"
                      ToolTip.Tip="Save tags">
                <material:MaterialIcon Width="14" Height="14" Kind="TagPlusOutline"/>
              </Button>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Custom lists" FontSize="12"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox x:Name="CustomListsBox"
                       Text="{Binding CustomListsText, Mode=OneWay}"
                       PlaceholderText="Friday queue, favorites"
                       FontSize="12">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Ctrl+Enter"
                              Command="{Binding SaveCustomListsCommand}"
                              CommandParameter="{Binding #CustomListsBox.Text}"/>
                </TextBox.KeyBindings>
              </TextBox>
              <Button Grid.Column="1" Classes="ghost" Width="34" Height="34" Padding="0"
                      Command="{Binding SaveCustomListsCommand}"
                      CommandParameter="{Binding #CustomListsBox.Text}"
                      ToolTip.Tip="Save custom lists">
                <material:MaterialIcon Width="14" Height="14" Kind="PlaylistPlus"/>
              </Button>
            </Grid>
          </StackPanel>

          <Border Classes="divider"/>

          <StackPanel Spacing="8">
            <TextBox x:Name="NotesBox"
                     Text="{Binding Notes}"
                     PlaceholderText="Personal notes…"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="68"
                     MaxHeight="140"
                     FontSize="12">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Ctrl+Enter"
                            Command="{Binding SaveNotesCommand}"
                            CommandParameter="{Binding #NotesBox.Text}"/>
              </TextBox.KeyBindings>
            </TextBox>
            <Button Classes="ghost" HorizontalAlignment="Right" Height="28"
                    Padding="12,0" FontSize="11"
                    Command="{Binding SaveNotesCommand}"
                    CommandParameter="{Binding #NotesBox.Text}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <material:MaterialIcon Width="12" Height="12" Kind="ContentSave"/>
                <TextBlock Text="Save notes"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <Border Classes="divider"/>

          <StackPanel Spacing="8">
            <TextBlock Text="Review" FontSize="12"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBox x:Name="ReviewBox"
                     Text="{Binding Review}"
                     PlaceholderText="Your review…"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="96"
                     MaxHeight="220"
                     FontSize="12">
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Ctrl+Enter"
                            Command="{Binding SaveReviewCommand}"
                            CommandParameter="{Binding #ReviewBox.Text}"/>
              </TextBox.KeyBindings>
            </TextBox>
            <Button Classes="ghost" HorizontalAlignment="Right" Height="28"
                    Padding="12,0" FontSize="11"
                    Command="{Binding SaveReviewCommand}"
                    CommandParameter="{Binding #ReviewBox.Text}">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <material:MaterialIcon Width="12" Height="12" Kind="ContentSave"/>
                <TextBlock Text="Save review"/>
              </StackPanel>
            </Button>
          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>

    <!-- ── Synopsis ────────────────────────────────────────────────── -->
    <Border Classes="panel" IsVisible="{Binding HasDescription}">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Classes="eyebrow-bar" Background="{DynamicResource TanaHubAccentLightBrush}"/>
          <TextBlock Classes="eyebrow" Text="SYNOPSIS" LetterSpacing="1"
                     Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
        </StackPanel>
        <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap"
                   Foreground="{DynamicResource TanaHubTextSecondaryBrush}" LineHeight="23"/>
      </StackPanel>
    </Border>

    <!-- ── Characters ──────────────────────────────────────────────── -->
    <StackPanel Spacing="10" IsVisible="{Binding HasCharacters}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border Classes="eyebrow-bar" Background="{DynamicResource TanaHubSakuraBrush}"/>
        <TextBlock Classes="eyebrow" Text="CHARACTERS" LetterSpacing="1"
                   Foreground="{DynamicResource TanaHubSakuraBrush}"/>
      </StackPanel>
      <ItemsControl ItemsSource="{Binding Characters}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="2"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="domain:CharacterInfo">
            <Border Background="{DynamicResource TanaHubSurfaceBrush}"
                    CornerRadius="10" Padding="10" Margin="0,0,8,8">
              <Grid ColumnDefinitions="52,*" ColumnSpacing="10">
                <Border Width="48" Height="64" CornerRadius="7" ClipToBounds="True">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                      <GradientStop Color="#3B1D63" Offset="0"/>
                      <GradientStop Color="#10131F" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <controls:RemoteImage SourceUri="{Binding ImageUri}"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                  <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                             Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                             TextTrimming="CharacterEllipsis"/>
                  <Border Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
                          CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
                  </Border>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

  </StackPanel>
</UserControl>
