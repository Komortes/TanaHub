<UserControl
    x:Class="TanaHub.UI.Views.Pages.LibraryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:TanaHub.UI.Views.Controls"
    x:DataType="vm:MainWindowViewModel">

  <Grid ColumnDefinitions="190,*" ColumnSpacing="20">

    <!-- ── Sidebar panels ─────────────────────────────────────── -->
    <StackPanel Spacing="14">
      <Border
          Padding="14"
          Background="{DynamicResource TanaHubSurfaceBrush}"
          BorderBrush="{DynamicResource TanaHubBorderBrush}"
          BorderThickness="1"
          CornerRadius="10"
          BoxShadow="0 2 8 0 #1C000000">
        <StackPanel Spacing="12">
          <TextBlock Text="Lists" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <StackPanel Spacing="4">
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="All">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="ViewList"/>
                <TextBlock Text="All"/>
              </StackPanel>
            </Button>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="Current">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="PlayCircleOutline"/>
                <TextBlock Text="Current"/>
              </StackPanel>
            </Button>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="Completed">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="CheckCircleOutline"/>
                <TextBlock Text="Completed"/>
              </StackPanel>
            </Button>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="Planning">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="BookmarkPlusOutline"/>
                <TextBlock Text="Planning"/>
              </StackPanel>
            </Button>
            <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="Paused">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="PauseCircleOutline"/>
                <TextBlock Text="Paused"/>
              </StackPanel>
            </Button>
            <Button Classes="ghost danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding SelectLibraryStatusCommand}" CommandParameter="Dropped">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <material:MaterialIcon Width="15" Height="15" Kind="CloseCircleOutline"/>
                <TextBlock Text="Dropped"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border
          Padding="14"
          Background="{DynamicResource TanaHubSurfaceBrush}"
          BorderBrush="{DynamicResource TanaHubBorderBrush}"
          BorderThickness="1"
          CornerRadius="10"
          BoxShadow="0 2 8 0 #1C000000">
        <StackPanel Spacing="10">
          <TextBlock Text="Sort" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="9">
            <TextBlock Text="Title" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Classes="mono" Grid.Column="1" Text="A-Z" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Grid.Row="1" Text="Score" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Classes="mono" Grid.Row="1" Grid.Column="1" Text="High" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Grid.Row="2" Text="Progress" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Classes="mono" Grid.Row="2" Grid.Column="1" Text="Active" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Grid.Row="3" Text="Updated" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Classes="mono" Grid.Row="3" Grid.Column="1" Text="Recent" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </Grid>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- ── Main list area ─────────────────────────────────────── -->
    <StackPanel Grid.Column="1" Spacing="12">

      <!-- Type + view toggle row -->
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Command="{Binding SelectLibraryTypeCommand}" CommandParameter="All">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <material:MaterialIcon Width="15" Height="15" Kind="ViewGrid"/>
              <TextBlock Text="All"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding SelectLibraryTypeCommand}" CommandParameter="Anime">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <material:MaterialIcon Width="15" Height="15" Kind="MovieOpenPlay"/>
              <TextBlock Text="Anime"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding SelectLibraryTypeCommand}" CommandParameter="Manga">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <material:MaterialIcon Width="15" Height="15" Kind="BookOpenPageVariant"/>
              <TextBlock Text="Manga"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <Border Grid.Column="1" Height="32" Padding="9,0" CornerRadius="8"
                Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
                BorderBrush="{DynamicResource TanaHubBorderBrush}" BorderThickness="1">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <material:MaterialIcon Width="14" Height="14" Kind="ViewGrid" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <TextBlock Text="Grid" FontSize="12" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <Border Width="1" Height="14" Background="{DynamicResource TanaHubBorderBrush}"/>
            <material:MaterialIcon Width="14" Height="14" Kind="ViewList" Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
            <TextBlock Text="List" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
          </StackPanel>
        </Border>

        <Button Classes="ghost" Grid.Column="2" Height="32" Command="{Binding RefreshLibraryCommand}">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <material:MaterialIcon Width="15" Height="15" Kind="Refresh"/>
            <TextBlock Text="Refresh"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Column headers -->
      <Border
          Padding="12,7"
          Background="{DynamicResource TanaHubSurfaceRaisedBrush}"
          BorderBrush="{DynamicResource TanaHubBorderBrush}"
          BorderThickness="0,0,0,1"
          CornerRadius="8,8,0,0">
        <Grid ColumnDefinitions="52,*,96,78,64,36,132" ColumnSpacing="10">
          <TextBlock Grid.Column="1" Text="TITLE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          <TextBlock Grid.Column="2" Text="STATUS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          <TextBlock Grid.Column="3" Text="PROGRESS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          <TextBlock Grid.Column="4" Text="SCORE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
        </Grid>
      </Border>

      <!-- List rows -->
      <ItemsControl ItemsSource="{Binding LibraryEntries}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LibraryEntryViewModel">
            <Border
                Margin="0,0,0,4"
                Background="{DynamicResource TanaHubSurfaceBrush}"
                BorderBrush="{DynamicResource TanaHubBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True">
              <Border.Transitions>
                <Transitions>
                  <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
              </Border.Transitions>
              <Border.Styles>
                <Style Selector="Border:pointerover">
                  <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
                </Style>
              </Border.Styles>
              <Grid ColumnDefinitions="3,*">
                <!-- Hover accent stripe -->
                <Border Classes="row-stripe" CornerRadius="10,0,0,10">
                  <Border.Styles>
                    <Style Selector="Border.row-stripe">
                      <Setter Property="Background" Value="Transparent"/>
                      <Setter Property="Transitions">
                        <Setter.Value>
                          <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.16"/>
                          </Transitions>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Border.Styles>
                </Border>
                <!-- Row content -->
                <Grid Grid.Column="1" ColumnDefinitions="52,*,96,78,64,36,132" ColumnSpacing="10" Margin="10,10,12,10">
                  <Border Width="38" Height="52" CornerRadius="7" ClipToBounds="True">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#38215F" Offset="0"/>
                        <GradientStop Color="#10131F" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                  </StackPanel>
                  <Border Grid.Column="2" Height="22" Padding="8,0" CornerRadius="6" VerticalAlignment="Center"
                          Background="{DynamicResource TanaHubSurfaceElevatedBrush}"
                          BorderBrush="{DynamicResource TanaHubBorderBrush}"
                          BorderThickness="1">
                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{Binding StatusForeground}"/>
                  </Border>
                  <TextBlock Classes="mono" Grid.Column="3" Text="{Binding Progress}" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource TanaHubCyanBrush}"/>
                  <TextBlock Classes="mono" Grid.Column="4" Text="{Binding Score}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{Binding ScoreForeground}"/>
                  <Button Classes="ghost" Grid.Column="5" Width="30" Height="30" Padding="0" VerticalAlignment="Center"
                          Command="{Binding OpenDetailCommand}" ToolTip.Tip="View details">
                    <material:MaterialIcon Width="15" Height="15" Kind="ChevronRight" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                  </Button>
                  <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Width="30" Height="30" Padding="0" Command="{Binding IncrementCommand}" ToolTip.Tip="Increment progress">
                      <material:MaterialIcon Width="16" Height="16" Kind="Plus"/>
                    </Button>
                    <Button Width="30" Height="30" Padding="0" Command="{Binding IncreaseScoreCommand}" ToolTip.Tip="Increase score">
                      <material:MaterialIcon Width="16" Height="16" Kind="StarPlus"/>
                    </Button>
                    <Button Width="30" Height="30" Padding="0" Command="{Binding MarkCompletedCommand}" ToolTip.Tip="Mark completed">
                      <material:MaterialIcon Width="16" Height="16" Kind="CheckCircleOutline"/>
                    </Button>
                    <Button Classes="danger" Width="30" Height="30" Padding="0" Command="{Binding RemoveCommand}" ToolTip.Tip="Remove from library">
                      <material:MaterialIcon Width="16" Height="16" Kind="TrashCanOutline"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Grid>
</UserControl>
