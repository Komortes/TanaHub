<UserControl
    x:Class="TanaHub.UI.Views.Pages.LibraryView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:TanaHub.UI.Views.Controls"
    x:DataType="vm:MainWindowViewModel">


  <Grid ColumnDefinitions="220,*" ColumnSpacing="20">

    <!-- ── Sidebar — unified panel ──────────────────────────────── -->
    <Border Classes="panel">
      <StackPanel Spacing="20">

        <!-- LISTS section -->
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="7" Margin="2,0,0,4">
            <Border Width="3" Height="11" CornerRadius="2" VerticalAlignment="Center"
                    Background="{DynamicResource TanaHubAccentBrush}"/>
            <TextBlock Text="LISTS" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>
          <ListBox
              ItemsSource="{Binding LibraryStatusFilters}"
              SelectedItem="{Binding SelectedLibraryStatus, Mode=TwoWay}"
              Background="Transparent" BorderThickness="0" Padding="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,1"/>
                <Setter Property="CornerRadius" Value="8"/>
              </Style>
              <Style Selector="ListBoxItem /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="10,9"/>
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TanaHubAccentGlowBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}"/>
                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="CornerRadius" Value="0,8,8,0"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover:not(:selected) /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
              </Style>
              <Style Selector="ListBoxItem TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TanaHubTextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
              </Style>
              <Style Selector="ListBoxItem:selected TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TanaHubAccentLightBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Style>
            </ListBox.Styles>
          </ListBox>
        </StackPanel>

        <!-- Section divider -->
        <Border Classes="divider" Margin="2,0"/>

        <!-- SORT section -->
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="7" Margin="2,0,0,4">
            <Border Width="3" Height="11" CornerRadius="2" VerticalAlignment="Center"
                    Background="{DynamicResource TanaHubCyanBrush}"/>
            <TextBlock Text="SORT" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>
          <ListBox
              ItemsSource="{Binding LibrarySortOptions}"
              SelectedItem="{Binding SelectedLibrarySort, Mode=TwoWay}"
              Background="Transparent" BorderThickness="0" Padding="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,1"/>
                <Setter Property="CornerRadius" Value="8"/>
              </Style>
              <Style Selector="ListBoxItem /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="10,9"/>
              </Style>
              <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TanaHubCyanGlowBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource TanaHubCyanBrush}"/>
                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="CornerRadius" Value="0,8,8,0"/>
              </Style>
              <Style Selector="ListBoxItem:pointerover:not(:selected) /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
              </Style>
              <Style Selector="ListBoxItem TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TanaHubTextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
              </Style>
              <Style Selector="ListBoxItem:selected TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TanaHubCyanBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Style>
            </ListBox.Styles>
          </ListBox>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ── Main content ────────────────────────────────────────── -->
    <StackPanel Grid.Column="1" Spacing="12">

      <!-- Search bar -->
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBox
            Height="34"
            PlaceholderText="Search your library..."
            Text="{Binding LibrarySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
          <TextBox.InnerLeftContent>
            <material:MaterialIcon Width="15" Height="15" Kind="Magnify" Margin="8,0,4,0"
                                   Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </TextBox.InnerLeftContent>
          <TextBox.KeyBindings>
            <KeyBinding Gesture="Enter" Command="{Binding SearchLibraryCommand}"/>
          </TextBox.KeyBindings>
        </TextBox>
        <Button Grid.Column="1" Height="34" Command="{Binding SearchLibraryCommand}">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <material:MaterialIcon Width="15" Height="15" Kind="Magnify"/>
            <TextBlock Text="Search"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Type tabs + view mode toggle + refresh -->
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

        <!-- Type tabs -->
        <StackPanel Orientation="Horizontal" Spacing="4">
          <StackPanel Spacing="2">
            <Button Classes="ghost" Command="{Binding SelectLibraryTypeCommand}" CommandParameter="All">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="14" Height="14" Kind="ViewGrid"/>
                <TextBlock Text="All"/>
              </StackPanel>
            </Button>
            <Border Height="2" CornerRadius="1" Background="{DynamicResource TanaHubAccentBrush}"
                    IsVisible="{Binding IsLibraryAllSelected}"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <Button Classes="ghost" Command="{Binding SelectLibraryTypeCommand}" CommandParameter="Anime">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="14" Height="14" Kind="MovieOpenPlay"/>
                <TextBlock Text="Anime"/>
              </StackPanel>
            </Button>
            <Border Height="2" CornerRadius="1" Background="{DynamicResource TanaHubAccentBrush}"
                    IsVisible="{Binding IsLibraryAnimeSelected}"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <Button Classes="ghost" Command="{Binding SelectLibraryTypeCommand}" CommandParameter="Manga">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="14" Height="14" Kind="BookOpenPageVariant"/>
                <TextBlock Text="Manga"/>
              </StackPanel>
            </Button>
            <Border Height="2" CornerRadius="1" Background="{DynamicResource TanaHubAccentBrush}"
                    IsVisible="{Binding IsLibraryMangaSelected}"/>
          </StackPanel>
        </StackPanel>

        <!-- View mode toggle with active underline indicator -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
          <StackPanel Spacing="2">
            <Button Classes="ghost" Width="34" Height="30" Padding="0"
                    Command="{Binding SelectLibraryViewModeCommand}" CommandParameter="List"
                    ToolTip.Tip="List view">
              <material:MaterialIcon Width="15" Height="15" Kind="ViewList"/>
            </Button>
            <Border Height="2" CornerRadius="1" Background="{DynamicResource TanaHubAccentBrush}"
                    IsVisible="{Binding IsLibraryListMode}"/>
          </StackPanel>
          <StackPanel Spacing="2">
            <Button Classes="ghost" Width="34" Height="30" Padding="0"
                    Command="{Binding SelectLibraryViewModeCommand}" CommandParameter="Grid"
                    ToolTip.Tip="Grid view">
              <material:MaterialIcon Width="15" Height="15" Kind="ViewGrid"/>
            </Button>
            <Border Height="2" CornerRadius="1" Background="{DynamicResource TanaHubAccentBrush}"
                    IsVisible="{Binding IsLibraryGridMode}"/>
          </StackPanel>
        </StackPanel>

        <Button Classes="ghost" Grid.Column="2" Height="34" Command="{Binding RefreshLibraryCommand}">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <material:MaterialIcon Width="15" Height="15" Kind="Refresh"/>
            <TextBlock Text="Refresh"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- ── Empty state ────────────────────────────────────────── -->
      <Border Classes="panel" IsVisible="{Binding IsLibraryEmpty}" Padding="48,56">
        <StackPanel HorizontalAlignment="Center" Spacing="16">
          <material:MaterialIcon Width="52" Height="52" Kind="Bookshelf"
                                 Foreground="{DynamicResource TanaHubTextMutedBrush}"
                                 HorizontalAlignment="Center"/>
          <StackPanel Spacing="6" HorizontalAlignment="Center">
            <TextBlock Text="{Binding LibraryEmptyMessage}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Find anime and manga on the Discover page and add them to your collection."
                       FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
          <Button HorizontalAlignment="Center" Command="{Binding NavigateToDiscoverCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="Magnify"/>
              <TextBlock Text="Discover titles"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <!-- ── List view ──────────────────────────────────────────── -->
      <StackPanel IsVisible="{Binding IsLibraryListVisible}" Spacing="4">

        <!-- Column headers -->
        <Border
            IsVisible="{Binding !IsLibraryEmpty}"
            Padding="12,8"
            CornerRadius="8">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
              <GradientStop Color="#9B6EF814" Offset="0"/>
              <GradientStop Color="#22D3EE0A" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
          <Grid ColumnDefinitions="48,*,96,78,60,128" ColumnSpacing="10">
            <TextBlock Grid.Column="1" Text="TITLE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="STATUS" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="PROGRESS" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="SCORE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Column="5" Text="ACTIONS" FontSize="10" FontWeight="SemiBold"
                       HorizontalAlignment="Left"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
          </Grid>
        </Border>

        <!-- Rows — individual glass cards, each clickable -->
        <ItemsControl IsVisible="{Binding !IsLibraryEmpty}" ItemsSource="{Binding LibraryEntries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:LibraryEntryViewModel">
              <Button Classes="row" Padding="12,10" CornerRadius="8"
                      Command="{Binding OpenDetailCommand}">
                <Grid ColumnDefinitions="48,*,96,78,60,128" ColumnSpacing="10">
                  <Border Width="36" Height="50" CornerRadius="7" ClipToBounds="True">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#38215F" Offset="0"/>
                        <GradientStop Color="#10131F" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Type}" FontSize="11"
                               Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
                  </StackPanel>
                  <Border Grid.Column="2" Height="22" Padding="8,0" CornerRadius="6" VerticalAlignment="Center"
                          Background="{DynamicResource TanaHubSurfaceElevatedBrush}">
                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{Binding StatusForeground}"/>
                  </Border>
                  <TextBlock Classes="mono" Grid.Column="3" Text="{Binding Progress}"
                             FontSize="12" VerticalAlignment="Center"
                             Foreground="{DynamicResource TanaHubCyanBrush}"/>
                  <TextBlock Classes="mono" Grid.Column="4" Text="{Binding Score}"
                             FontSize="13" FontWeight="Bold" VerticalAlignment="Center"
                             Foreground="{Binding ScoreForeground}"/>
                  <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Classes="ghost" Width="30" Height="30" Padding="0" Command="{Binding IncrementCommand}" ToolTip.Tip="Increment progress">
                      <material:MaterialIcon Width="16" Height="16" Kind="Plus"/>
                    </Button>
                    <Button Classes="ghost" Width="30" Height="30" Padding="0" Command="{Binding IncreaseScoreCommand}" ToolTip.Tip="Increase score">
                      <material:MaterialIcon Width="16" Height="16" Kind="StarPlus"/>
                    </Button>
                    <Button Classes="ghost" Width="30" Height="30" Padding="0" Command="{Binding MarkCompletedCommand}" ToolTip.Tip="Mark completed">
                      <material:MaterialIcon Width="16" Height="16" Kind="CheckCircleOutline"/>
                    </Button>
                    <Button Classes="danger" Width="30" Height="30" Padding="0" Command="{Binding RemoveCommand}" ToolTip.Tip="Remove from library">
                      <material:MaterialIcon Width="16" Height="16" Kind="TrashCanOutline"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>

      <!-- ── Grid view ──────────────────────────────────────────── -->
      <ItemsControl IsVisible="{Binding IsLibraryGridVisible}" ItemsSource="{Binding LibraryEntries}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel ItemWidth="184"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LibraryEntryViewModel">
            <Button Classes="card" Command="{Binding OpenDetailCommand}"
                    Width="172" Height="262" Margin="0,0,12,12"
                    RenderTransformOrigin="0.5,0.5">
              <Border Classes="card" ClipToBounds="True">
                <Grid RowDefinitions="154,*,Auto">
                  <Border>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#38215F" Offset="0"/>
                        <GradientStop Color="#10131F" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <controls:RemoteImage SourceUri="{Binding PosterUri}"/>
                  </Border>
                  <StackPanel Grid.Row="1" Margin="12,10,12,0" Spacing="4">
                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TanaHubTextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Status}" FontSize="11"
                                 Foreground="{Binding StatusForeground}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Classes="mono" Grid.Column="1" Text="{Binding Score}"
                                 FontSize="12" FontWeight="Bold" Foreground="{Binding ScoreForeground}"/>
                    </Grid>
                    <TextBlock Classes="mono" Text="{Binding Progress}" FontSize="11"
                               Foreground="{DynamicResource TanaHubCyanBrush}"/>
                  </StackPanel>
                  <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="12,0,12,12">
                    <Button Classes="ghost" Width="30" Height="30" Padding="0" Command="{Binding IncrementCommand}" ToolTip.Tip="Increment progress">
                      <material:MaterialIcon Width="15" Height="15" Kind="Plus"/>
                    </Button>
                    <Button Classes="ghost" Width="30" Height="30" Padding="0" Command="{Binding IncreaseScoreCommand}" ToolTip.Tip="Increase score">
                      <material:MaterialIcon Width="15" Height="15" Kind="StarPlus"/>
                    </Button>
                    <Button Classes="danger" Width="30" Height="30" Padding="0" Command="{Binding RemoveCommand}" ToolTip.Tip="Remove from library">
                      <material:MaterialIcon Width="15" Height="15" Kind="TrashCanOutline"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </Grid>
</UserControl>
