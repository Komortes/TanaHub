<UserControl
    x:Class="TanaHub.UI.Views.Pages.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:TanaHub.UI.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:DataType="vm:MainWindowViewModel">

  <StackPanel Spacing="18">
    <Grid ColumnDefinitions="1.1*,*" ColumnSpacing="18">

      <!-- Runtime info -->
      <Border Classes="panel">
        <StackPanel Spacing="14">
          <StackPanel Spacing="3">
            <TextBlock Text="Runtime" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <TextBlock Text="Current development wiring" FontSize="12" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
          </StackPanel>
          <Border Classes="divider"/>
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="130,*" RowSpacing="10">
            <TextBlock Text="Mode" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="File-backed library and settings" FontSize="12" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <TextBlock Grid.Row="1" Text="Theme" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SettingsTheme}" FontSize="12" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <TextBlock Grid.Row="2" Text="Sync" FontSize="12" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreferredSyncSource}" FontSize="12" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Storage info -->
      <Border Grid.Column="1" Classes="panel">
        <StackPanel Spacing="12">
          <TextBlock Text="Storage" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <TextBlock Text="Library and preferences persist to local JSON files between app launches." FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
          <Border Classes="divider" Margin="0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <material:MaterialIcon Width="16" Height="16" Kind="DatabaseCheck" Foreground="{DynamicResource TanaHubGreenBrush}"/>
            <TextBlock Text="{Binding SettingsStorageDetail}" FontSize="12" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">

      <!-- Data sources -->
      <Border Classes="panel">
        <StackPanel Spacing="16">
          <TextBlock Text="Data source" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="34,*,Auto" RowSpacing="14">

            <!-- AniList -->
            <material:MaterialIcon Width="18" Height="18" Kind="CloudSync" Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="AniList" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="Search, metadata and airing schedule" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <Button Classes="ghost" Grid.Column="2" Height="30" Padding="10,0" VerticalAlignment="Center"
                    Command="{Binding SelectSyncSourceCommand}" CommandParameter="AniList">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="13" Height="13" Kind="Check" IsVisible="{Binding IsAniListSyncSelected}"/>
                <TextBlock Text="Use" FontSize="11"/>
              </StackPanel>
            </Button>

            <!-- MAL -->
            <material:MaterialIcon Grid.Row="1" Width="18" Height="18" Kind="CloudSync" Foreground="{DynamicResource TanaHubAccentLightBrush}"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
              <TextBlock Text="MyAnimeList" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="Preferred future list synchronization source" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <Button Classes="ghost" Grid.Row="1" Grid.Column="2" Height="30" Padding="10,0" VerticalAlignment="Center"
                    Command="{Binding SelectSyncSourceCommand}" CommandParameter="MyAnimeList">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="13" Height="13" Kind="Check" IsVisible="{Binding IsMyAnimeListSyncSelected}"/>
                <TextBlock Text="Use" FontSize="11"/>
              </StackPanel>
            </Button>

            <!-- MangaDex -->
            <material:MaterialIcon Grid.Row="2" Width="18" Height="18" Kind="BookSearch" Foreground="{DynamicResource TanaHubCyanBrush}"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
              <TextBlock Text="MangaDex" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="Preferred future manga metadata source" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <Button Classes="ghost" Grid.Row="2" Grid.Column="2" Height="30" Padding="10,0" VerticalAlignment="Center"
                    Command="{Binding SelectSyncSourceCommand}" CommandParameter="MangaDex">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon Width="13" Height="13" Kind="Check" IsVisible="{Binding IsMangaDexSyncSelected}"/>
                <TextBlock Text="Use" FontSize="11"/>
              </StackPanel>
            </Button>

          </Grid>
        </StackPanel>
      </Border>

      <!-- Preferences -->
      <Border Grid.Column="1" Classes="panel">
        <StackPanel Spacing="16">
          <TextBlock Text="Preferences" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="14">
            <StackPanel Spacing="2">
              <TextBlock Text="Notifications" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="Episode and chapter release alerts" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding NotificationsEnabled, Mode=OneWay}"
                          Command="{Binding ToggleNotificationsCommand}"/>

            <StackPanel Grid.Row="1" Spacing="2">
              <TextBlock Text="Offline cache" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="Keep metadata available without network" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding OfflineCacheEnabled, Mode=OneWay}"
                          Command="{Binding ToggleOfflineCacheCommand}"/>

            <StackPanel Grid.Row="2" Spacing="2">
              <TextBlock Text="Recognition" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
              <TextBlock Text="trace.moe and SauceNAO integrations" FontSize="11" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding RecognitionServicesEnabled, Mode=OneWay}"
                          Command="{Binding ToggleRecognitionServicesCommand}"/>
          </Grid>

          <Border Classes="divider"/>

          <StackPanel Spacing="6">
            <TextBlock Text="Theme" FontSize="12" Foreground="{DynamicResource TanaHubTextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="7">
              <StackPanel Spacing="2">
                <Button Classes="ghost" Command="{Binding SelectThemeCommand}" CommandParameter="Nebula dark">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="14" Height="14" Kind="MoonWaningCrescent"/>
                    <TextBlock Text="Nebula"/>
                  </StackPanel>
                </Button>
                <Border Height="2" Background="{DynamicResource TanaHubAccentBrush}"
                        IsVisible="{Binding IsNebulaThemeSelected}"/>
              </StackPanel>
              <StackPanel Spacing="2">
                <Button Classes="ghost" Command="{Binding SelectThemeCommand}" CommandParameter="High contrast">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Width="14" Height="14" Kind="ContrastCircle"/>
                    <TextBlock Text="High contrast"/>
                  </StackPanel>
                </Button>
                <Border Height="2" Background="{DynamicResource TanaHubAccentBrush}"
                        IsVisible="{Binding IsHighContrastThemeSelected}"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <!-- AniList account -->
    <Border Classes="panel">
      <StackPanel Spacing="16">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="3">
            <TextBlock Text="AniList account" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <material:MaterialIcon Width="13" Height="13" Kind="CheckCircle"
                                     Foreground="{DynamicResource TanaHubGreenBrush}"
                                     IsVisible="{Binding IsAniListConnected}"/>
              <TextBlock Text="{Binding AniListConnectionStatus}" FontSize="12"
                         Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            </StackPanel>
          </StackPanel>
          <!-- Actions when connected -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7"
                      IsVisible="{Binding IsAniListConnected}" VerticalAlignment="Center">
            <StackPanel Spacing="2">
              <Button Command="{Binding SyncFromAniListCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <material:MaterialIcon Width="15" Height="15" Kind="CloudSync"/>
                  <TextBlock Text="Sync library"/>
                </StackPanel>
              </Button>
              <TextBlock Text="{Binding AniListSyncStatus}" FontSize="10"
                         Foreground="{DynamicResource TanaHubTextMutedBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
            <Button Classes="danger" Command="{Binding DisconnectAniListCommand}" ToolTip.Tip="Disconnect AniList">
              <material:MaterialIcon Width="15" Height="15" Kind="LinkOff"/>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Credentials (shown only when not connected) -->
        <StackPanel IsVisible="{Binding !IsAniListConnected}" Spacing="12">
          <Border Classes="divider"/>
          <TextBlock FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource TanaHubTextSecondaryBrush}">
            Create an OAuth2 app at anilist.co/settings/developer with redirect URI
            http://localhost:7575/callback/ then paste the credentials below.
          </TextBlock>
          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="110,*" RowSpacing="8" ColumnSpacing="10">
            <TextBlock Text="Client ID" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBox Grid.Column="1" Height="34" PlaceholderText="e.g. 12345"
                     Text="{Binding AniListClientId, Mode=TwoWay}"/>
            <TextBlock Grid.Row="1" Text="Client Secret" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
            <TextBox Grid.Row="1" Grid.Column="1" Height="34" PasswordChar="●"
                     PlaceholderText="Paste secret here"
                     Text="{Binding AniListClientSecret, Mode=TwoWay}"/>
          </Grid>
          <Button Command="{Binding ConnectAniListCommand}" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="OpenInBrowser"/>
              <TextBlock Text="Connect AniList"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Library import/export -->
    <Border Classes="panel">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
        <StackPanel Spacing="4">
          <TextBlock Text="Library import / export" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TanaHubTextPrimaryBrush}"/>
          <TextBlock Text="{Binding LibraryExportStatus}" FontSize="12"
                     Foreground="{DynamicResource TanaHubTextSecondaryBrush}"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Command="{Binding ImportMalXmlCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="FileImportOutline"/>
              <TextBlock Text="Import MAL XML"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding ExportMalXmlCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="FileExportOutline"/>
              <TextBlock Text="Export MAL XML"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding ExportLibraryCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <material:MaterialIcon Width="15" Height="15" Kind="FileExportOutline"/>
              <TextBlock Text="Export CSV"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>
  </StackPanel>
</UserControl>
