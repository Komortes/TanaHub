<Application
    x:Class="TanaHub.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Dark">
  <Application.Resources>

    <!-- ── Surfaces ──────────────────────────────────────────── -->
    <Color x:Key="TanaHubBackgroundColor">#09080F</Color>
    <Color x:Key="TanaHubSurfaceColor">#120F1C</Color>
    <Color x:Key="TanaHubSurfaceRaisedColor">#1A1628</Color>
    <Color x:Key="TanaHubSurfaceElevatedColor">#201C30</Color>
    <Color x:Key="TanaHubSurfaceHoverColor">#271F38</Color>
    <Color x:Key="TanaHubBorderColor">#2C2244</Color>
    <Color x:Key="TanaHubBorderLightColor">#3C2E58</Color>

    <!-- ── Accent / Primary ───────────────────────────────────── -->
    <Color x:Key="TanaHubAccentColor">#9B6EF8</Color>
    <Color x:Key="TanaHubAccentLightColor">#C8B8FF</Color>
    <Color x:Key="TanaHubAccentGlowColor">#9B6EF82E</Color>
    <Color x:Key="TanaHubAccentGlowStrongColor">#9B6EF848</Color>

    <!-- ── Secondary palette ──────────────────────────────────── -->
    <Color x:Key="TanaHubCyanColor">#22D3EE</Color>
    <Color x:Key="TanaHubCyanGlowColor">#22D3EE1E</Color>
    <Color x:Key="TanaHubSakuraColor">#F472B6</Color>
    <Color x:Key="TanaHubAmberColor">#F59E0B</Color>

    <!-- ── Status colours ─────────────────────────────────────── -->
    <Color x:Key="TanaHubGreenColor">#10B981</Color>
    <Color x:Key="TanaHubGreenGlowColor">#10B9811E</Color>
    <Color x:Key="TanaHubOrangeColor">#F97316</Color>
    <Color x:Key="TanaHubRedColor">#EF4444</Color>

    <!-- ── Text ───────────────────────────────────────────────── -->
    <Color x:Key="TanaHubTextPrimaryColor">#EDE9FF</Color>
    <Color x:Key="TanaHubTextSecondaryColor">#A99EC0</Color>
    <Color x:Key="TanaHubTextMutedColor">#6B6080</Color>

    <!-- ── Brushes ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TanaHubBackgroundBrush"      Color="{StaticResource TanaHubBackgroundColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceBrush"         Color="{StaticResource TanaHubSurfaceColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceRaisedBrush"   Color="{StaticResource TanaHubSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceElevatedBrush" Color="{StaticResource TanaHubSurfaceElevatedColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceHoverBrush"    Color="{StaticResource TanaHubSurfaceHoverColor}" />
    <SolidColorBrush x:Key="TanaHubBorderBrush"          Color="{StaticResource TanaHubBorderColor}" />
    <SolidColorBrush x:Key="TanaHubBorderLightBrush"     Color="{StaticResource TanaHubBorderLightColor}" />
    <SolidColorBrush x:Key="TanaHubAccentBrush"          Color="{StaticResource TanaHubAccentColor}" />
    <SolidColorBrush x:Key="TanaHubAccentLightBrush"     Color="{StaticResource TanaHubAccentLightColor}" />
    <SolidColorBrush x:Key="TanaHubAccentGlowBrush"      Color="{StaticResource TanaHubAccentGlowColor}" />
    <SolidColorBrush x:Key="TanaHubAccentGlowStrongBrush" Color="{StaticResource TanaHubAccentGlowStrongColor}" />
    <SolidColorBrush x:Key="TanaHubCyanBrush"            Color="{StaticResource TanaHubCyanColor}" />
    <SolidColorBrush x:Key="TanaHubCyanGlowBrush"        Color="{StaticResource TanaHubCyanGlowColor}" />
    <SolidColorBrush x:Key="TanaHubSakuraBrush"          Color="{StaticResource TanaHubSakuraColor}" />
    <SolidColorBrush x:Key="TanaHubAmberBrush"           Color="{StaticResource TanaHubAmberColor}" />
    <SolidColorBrush x:Key="TanaHubGreenBrush"           Color="{StaticResource TanaHubGreenColor}" />
    <SolidColorBrush x:Key="TanaHubGreenGlowBrush"       Color="{StaticResource TanaHubGreenGlowColor}" />
    <SolidColorBrush x:Key="TanaHubOrangeBrush"          Color="{StaticResource TanaHubOrangeColor}" />
    <SolidColorBrush x:Key="TanaHubRedBrush"             Color="{StaticResource TanaHubRedColor}" />
    <SolidColorBrush x:Key="TanaHubTextPrimaryBrush"     Color="{StaticResource TanaHubTextPrimaryColor}" />
    <SolidColorBrush x:Key="TanaHubTextSecondaryBrush"   Color="{StaticResource TanaHubTextSecondaryColor}" />
    <SolidColorBrush x:Key="TanaHubTextMutedBrush"       Color="{StaticResource TanaHubTextMutedColor}" />

  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!-- ── Base text ─────────────────────────────────────────── -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI Variable, SF Pro Display, Cantarell, system-ui, sans-serif" />
    </Style>

    <!-- Monospace class — scores, progress counters, timestamps -->
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, Courier New, monospace" />
    </Style>

    <!-- ── Buttons ───────────────────────────────────────────── -->
    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
            <BrushTransition Property="Background" Duration="0:0:0.14"/>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentLightBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentLightBrush}" />
      <Setter Property="Foreground" Value="#100B1B" />
    </Style>

    <!-- Ghost / secondary button — use Classes="ghost" -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.ghost:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>

    <!-- Danger / destructive ghost -->
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextMutedBrush}" />
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="#3F1515" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubRedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubRedBrush}" />
    </Style>

    <!-- ── TextBox ───────────────────────────────────────────── -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            <BrushTransition Property="Background" Duration="0:0:0.15"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceElevatedBrush}" />
    </Style>

    <!-- ── ScrollBar ─────────────────────────────────────────── -->
    <Style Selector="ScrollBar">
      <Setter Property="Opacity" Value="0.4"/>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="ScrollBar:pointerover">
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

  </Application.Styles>
</Application>
