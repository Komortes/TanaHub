<Application
    x:Class="TanaHub.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    RequestedThemeVariant="Dark">
  <Application.Resources>

    <!-- ── Surfaces ──────────────────────────────────────────── -->
    <Color x:Key="TanaHubBackgroundColor">#07060E</Color>
    <Color x:Key="TanaHubSurfaceColor">#100D1A</Color>
    <Color x:Key="TanaHubSurfaceRaisedColor">#181426</Color>
    <Color x:Key="TanaHubSurfaceElevatedColor">#1E1A2E</Color>
    <Color x:Key="TanaHubSurfaceHoverColor">#231C34</Color>
    <!-- Accent-tinted borders — purple hue blends with the palette, no harsh white -->
    <Color x:Key="TanaHubBorderColor">#9B6EF818</Color>
    <Color x:Key="TanaHubBorderLightColor">#9B6EF830</Color>

    <!-- ── Accent / Primary ───────────────────────────────────── -->
    <Color x:Key="TanaHubAccentColor">#9B6EF8</Color>
    <Color x:Key="TanaHubAccentLightColor">#C8B8FF</Color>
    <Color x:Key="TanaHubAccentGlowColor">#9B6EF82E</Color>
    <Color x:Key="TanaHubAccentGlowStrongColor">#9B6EF848</Color>

    <!-- ── Secondary palette ──────────────────────────────────── -->
    <Color x:Key="TanaHubCyanColor">#22D3EE</Color>
    <Color x:Key="TanaHubCyanGlowColor">#22D3EE1E</Color>
    <Color x:Key="TanaHubSakuraColor">#F472B6</Color>
    <Color x:Key="TanaHubAmberColor">#F59E0B</Color>

    <!-- ── Status colours ─────────────────────────────────────── -->
    <Color x:Key="TanaHubGreenColor">#10B981</Color>
    <Color x:Key="TanaHubGreenGlowColor">#10B9811E</Color>
    <Color x:Key="TanaHubOrangeColor">#F97316</Color>
    <Color x:Key="TanaHubRedColor">#EF4444</Color>

    <!-- ── Text ───────────────────────────────────────────────── -->
    <Color x:Key="TanaHubTextPrimaryColor">#EDE9FF</Color>
    <Color x:Key="TanaHubTextSecondaryColor">#A99EC0</Color>
    <Color x:Key="TanaHubTextMutedColor">#6B6080</Color>

    <!-- ── Brushes ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TanaHubBackgroundBrush"      Color="{StaticResource TanaHubBackgroundColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceBrush"         Color="{StaticResource TanaHubSurfaceColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceRaisedBrush"   Color="{StaticResource TanaHubSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceElevatedBrush" Color="{StaticResource TanaHubSurfaceElevatedColor}" />
    <SolidColorBrush x:Key="TanaHubSurfaceHoverBrush"    Color="{StaticResource TanaHubSurfaceHoverColor}" />
    <SolidColorBrush x:Key="TanaHubBorderBrush"          Color="{StaticResource TanaHubBorderColor}" />
    <SolidColorBrush x:Key="TanaHubBorderLightBrush"     Color="{StaticResource TanaHubBorderLightColor}" />
    <SolidColorBrush x:Key="TanaHubAccentBrush"          Color="{StaticResource TanaHubAccentColor}" />
    <SolidColorBrush x:Key="TanaHubAccentLightBrush"     Color="{StaticResource TanaHubAccentLightColor}" />
    <SolidColorBrush x:Key="TanaHubAccentGlowBrush"      Color="{StaticResource TanaHubAccentGlowColor}" />
    <SolidColorBrush x:Key="TanaHubAccentGlowStrongBrush" Color="{StaticResource TanaHubAccentGlowStrongColor}" />
    <SolidColorBrush x:Key="TanaHubCyanBrush"            Color="{StaticResource TanaHubCyanColor}" />
    <SolidColorBrush x:Key="TanaHubCyanGlowBrush"        Color="{StaticResource TanaHubCyanGlowColor}" />
    <SolidColorBrush x:Key="TanaHubSakuraBrush"          Color="{StaticResource TanaHubSakuraColor}" />
    <SolidColorBrush x:Key="TanaHubAmberBrush"           Color="{StaticResource TanaHubAmberColor}" />
    <SolidColorBrush x:Key="TanaHubGreenBrush"           Color="{StaticResource TanaHubGreenColor}" />
    <SolidColorBrush x:Key="TanaHubGreenGlowBrush"       Color="{StaticResource TanaHubGreenGlowColor}" />
    <SolidColorBrush x:Key="TanaHubOrangeBrush"          Color="{StaticResource TanaHubOrangeColor}" />
    <SolidColorBrush x:Key="TanaHubRedBrush"             Color="{StaticResource TanaHubRedColor}" />
    <SolidColorBrush x:Key="TanaHubTextPrimaryBrush"     Color="{StaticResource TanaHubTextPrimaryColor}" />
    <SolidColorBrush x:Key="TanaHubTextSecondaryBrush"   Color="{StaticResource TanaHubTextSecondaryColor}" />
    <SolidColorBrush x:Key="TanaHubTextMutedBrush"       Color="{StaticResource TanaHubTextMutedColor}" />

    <!-- TextBox watermark / placeholder -->
    <SolidColorBrush x:Key="TextControlPlaceholderForeground"            Color="{StaticResource TanaHubTextMutedColor}"/>
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{StaticResource TanaHubTextMutedColor}"/>
    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"     Color="{StaticResource TanaHubTextMutedColor}"/>

    <!-- ToggleSwitch dark theme -->
    <SolidColorBrush x:Key="ToggleSwitchFillOff"            Color="{StaticResource TanaHubSurfaceRaisedColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="{StaticResource TanaHubSurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchFillOn"             Color="{StaticResource TanaHubAccentColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"  Color="{StaticResource TanaHubAccentLightColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchStrokeOff"          Color="{StaticResource TanaHubBorderLightColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchStrokeOn"           Color="{StaticResource TanaHubAccentColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOff"        Color="{StaticResource TanaHubTextSecondaryColor}"/>
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn"         Color="{StaticResource TanaHubTextPrimaryColor}"/>

  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <material:MaterialIconStyles />

    <!-- ── Base text ─────────────────────────────────────────── -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI Variable, SF Pro Display, Cantarell, system-ui, sans-serif" />
    </Style>

    <!-- Monospace class — scores, progress counters, timestamps -->
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="Cascadia Code, JetBrains Mono, Consolas, Courier New, monospace" />
    </Style>

    <!-- ── Buttons ───────────────────────────────────────────── -->
    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
            <BrushTransition Property="Background" Duration="0:0:0.14"/>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentLightBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentLightBrush}" />
      <Setter Property="Foreground" Value="#100B1B" />
    </Style>

    <!-- Ghost / secondary button — use Classes="ghost" -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderLightBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.ghost:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>

    <!-- Danger / destructive ghost -->
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextMutedBrush}" />
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="#3F1515" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubRedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubRedBrush}" />
    </Style>

    <!-- ToggleSwitch: hide default On/Off text labels -->
    <Style Selector="ToggleSwitch">
      <Setter Property="OnContent"  Value=""/>
      <Setter Property="OffContent" Value=""/>
    </Style>

    <!-- TextBox watermark text (belt-and-suspenders alongside resource keys above) -->
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextMutedBrush}"/>
    </Style>

    <!-- Icons and text inside buttons always vertically centred + foreground inherited -->
    <Style Selector="Button material|MaterialIcon">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}"/>
    </Style>
    <Style Selector="Button TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Poster card — transparent outer shell, inner Border handles visuals and rounded clip -->
    <Style Selector="Button.card">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.card:pointerover">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}"/>
      <Setter Property="RenderTransform" Value="translateY(-2px)"/>
    </Style>
    <Style Selector="Button.card:pressed">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>

    <!-- Row card — borderless, elevation from background contrast + spacing -->
    <Style Selector="Button.row">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,10"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.row:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.row:pressed">
      <Setter Property="RenderTransform" Value="scale(0.995)"/>
    </Style>

    <!-- ── TextBox ───────────────────────────────────────────── -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TanaHubTextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            <BrushTransition Property="Background" Duration="0:0:0.15"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource TanaHubAccentBrush}" />
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceElevatedBrush}" />
    </Style>

    <!-- ── ScrollBar ─────────────────────────────────────────── -->
    <Style Selector="ScrollBar">
      <Setter Property="Opacity" Value="0.4"/>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="ScrollBar:pointerover">
      <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <!-- ════ Surface system ════════════════════════════════════════
         One elevation language across every page: depth comes from a
         soft shadow + background contrast, never a hard 1px outline.
         Keeps panels from looking boxed-in. Radius scale steps cleanly:
         controls 8 · tiles 10 · cards 12 · panels 14. -->

    <!-- Large container — sidebars, settings blocks, detail panels -->
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceBrush}"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="BoxShadow" Value="0 8 28 0 #3A000000"/>
    </Style>

    <!-- Content card — list rows, schedule rows, media surfaces -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceBrush}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BoxShadow" Value="0 4 16 0 #2C000000"/>
    </Style>

    <!-- Flat list row — dense lists (schedule, search results). No shadow;
         separation comes from spacing + a hover lift to the raised surface,
         matching the Button.row treatment used on Home and Library. -->
    <Style Selector="Border.row">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceBrush}"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <BrushTransition Property="Background" Duration="0:0:0.14"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Border.row:pointerover">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
    </Style>

    <!-- Flat inset tile — mini stat tiles / nested surfaces, no shadow -->
    <Style Selector="Border.tile">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Small pill / badge -->
    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{DynamicResource TanaHubSurfaceRaisedBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Accent pill — selected / branded chip -->
    <Style Selector="Border.chip-accent">
      <Setter Property="Background" Value="{DynamicResource TanaHubAccentGlowBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Hairline divider -->
    <Style Selector="Border.divider">
      <Setter Property="Height" Value="1"/>
      <Setter Property="Background" Value="{DynamicResource TanaHubBorderLightBrush}"/>
    </Style>

    <!-- Section eyebrow accent bar — the 3px colour tick before a label -->
    <Style Selector="Border.eyebrow-bar">
      <Setter Property="Width" Value="3"/>
      <Setter Property="Height" Value="13"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Section eyebrow label — uppercase micro-heading -->
    <Style Selector="TextBlock.eyebrow">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

  </Application.Styles>
</Application>
